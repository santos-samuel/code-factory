      "Bash(git restore:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git show-ref:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh status:*)",
      "Bash(gh pr checkout:*)",
      "Bash(bzl run //:gazelle)",
      "Bash(bzl test:*)",
