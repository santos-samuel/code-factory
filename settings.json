      "Bash(rapid test:*)",
      "Bash(go test:*)",
      "Bash(go fmt:*)",
      "Bash(go vet:*)",
      "Bash(go build:*)",
      "Bash(go install:*)",
      "Bash(go mod:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(npm info:*)",
      "Bash(npm run build:*)",
      "Bash(npm run fmt:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",
      "MultiEdit(*)",
      "NotebookEdit(*)",
      "WebSearch(*)",
      "Skill(do)",
      "Skill(rfc)",
      "Skill(debug)",
      "Skill(execplan)",
      "Skill(doc)",
      "Skill(workspace)",
      "Skill(reflect)",
      "Skill(brag)",
      "Skill(daily)",
      "Skill(notes)",
      "Skill(skill-workbench)",
      "Skill(review)",
      "Skill(tour)",
      "Skill(performance-feedback)",
      "Skill(commit)",
      "Skill(atcommit)",
      "Skill(fixup)",
      "Skill(pr)",
      "Skill(branch)",
      "Skill(pr-fix)",
      "Skill(fix-conflicts)",
      "Skill(worktree)",
      "Task(*)",
      "TodoWrite(*)",
      "AskUserQuestion(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:docs.google.com)",
      "WebFetch(domain:docs.api.nvidia.com)",
      "WebFetch(domain:datadoghq.atlassian.net)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:platform.claude.com)",
