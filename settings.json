{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skillListingBudgetFraction": 0.05,
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "APPGATE_AUTOLAUNCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "MultiEdit",
      "NotebookEdit",
      "WebSearch",
      "Task",
      "TodoWrite",
      "AskUserQuestion",
      "TaskOutput",
      "TaskStop",
      "Skill(git:branch)",
      "Skill(git:commit)",
      "Skill(git:atcommit)",
      "Skill(git:fixup)",
      "Skill(git:pr)",
      "Skill(git:pr-fix)",
      "Skill(git:fix-conflicts)",
      "Skill(git:worktree)",
      "Skill(productivity:do)",
      "Skill(productivity:rfc)",
      "Skill(productivity:debug)",
      "Skill(productivity:doc)",
      "Skill(productivity:review)",
      "Skill(productivity:tour)",
      "Skill(productivity:reflect)",
      "Skill(productivity:wrap-up)",
      "Skill(productivity:brag)",
      "Skill(productivity:daily)",
      "Skill(productivity:notes)",
      "Skill(productivity:skill-workbench)",
      "Skill(productivity:performance-feedback)",
      "Skill(productivity:brainstorm)",
      "Skill(productivity:code-simplify)",
      "Skill(productivity:workspace)",
      "Skill(productivity:datadog)",
      "Skill(productivity:ai-cli)",
      "Skill(dd:*)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:docs.google.com)",
      "WebFetch(domain:docs.api.nvidia.com)",
      "WebFetch(domain:datadoghq.atlassian.net)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:opencode.ai)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:resources.anthropic.com)",
      "WebFetch(domain:agentskills.io)",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:developers.openai.com)",
      "mcp__atlassian__atlassianUserInfo",
      "mcp__atlassian__fetchAtlassian",
      "mcp__atlassian__getAccessibleAtlassianResources",
      "mcp__atlassian__getConfluenceCommentChildren",
      "mcp__atlassian__getConfluencePage",
      "mcp__atlassian__getConfluencePageDescendants",
      "mcp__atlassian__getConfluencePageFooterComments",
      "mcp__atlassian__getConfluencePageInlineComments",
      "mcp__atlassian__getConfluenceSpaces",
      "mcp__atlassian__getIssueLinkTypes",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__getJiraIssueRemoteIssueLinks",
      "mcp__atlassian__getJiraIssueTypeMetaWithFields",
      "mcp__atlassian__getJiraProjectIssueTypesMetadata",
      "mcp__atlassian__getPagesInConfluenceSpace",
      "mcp__atlassian__getTransitionsForJiraIssue",
      "mcp__atlassian__getVisibleJiraProjects",
      "mcp__atlassian__lookupJiraAccountId",
      "mcp__atlassian__searchAtlassian",
      "mcp__atlassian__searchConfluenceUsingCql",
      "mcp__atlassian__searchJiraIssuesUsingJql",
      "mcp__slack__slack_read_channel",
      "mcp__slack__slack_read_thread",
      "mcp__slack__slack_read_user_profile",
      "mcp__slack__slack_search_channels",
      "mcp__slack__slack_search_users",
      "mcp__slack__slack_search_public",
      "mcp__slack__slack_search_public_and_private",
      "mcp__slack__slack_read_canvas",
      "mcp__datadog-google-workspace__read_document",
      "mcp__datadog-google-workspace__read_sheet",
      "mcp__datadog-google-workspace__get_spreadsheet_metadata",
      "mcp__datadog-google-workspace__search_files",
      "mcp__datadog-google-workspace__list_folder_contents",
      "mcp__datadog-google-workspace__get_file_content",
      "mcp__datadog-google-workspace__get_file_metadata"
    ],
    "ask": [
      "Bash(sudo *)",
      "Bash(dd if= *)",
      "Bash(dd of= *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(diskutil erase *)",
      "Bash(diskutil partitionDisk *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(nvram *)",
      "Bash(csrutil *)",
      "Bash(launchctl *)",
      "Bash(systemsetup *)",
      "Bash(networksetup *)",
      "Bash(rm -r *)",
      "Bash(rm -fr *)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git branch -D *)",
      "Bash(git checkout --  *)",
      "Bash(git rebase *)",
      "Bash(git stash drop *)",
      "Bash(brew install *)",
      "Bash(npm install -g *)",
      "Bash(defaults write *)"
    ],
    "defaultMode": "plan",
    "additionalDirectories": [
      "~/dd",
      "~/go",
      "/tmp",
      "/private/var/tmp"
    ]
  },
  "enabledMcpjsonServers": [
    "atlassian",
    "datadog-google-workspace",
    "chrome-devtools",
    "slack"
  ],
  "disabledMcpjsonServers": [
    "datadog"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/command-safety-scanner.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-phrase-guard.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/brag-reminder.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "PATH=\"$HOME/.local/node/bin:$PATH\" npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "productivity@code-factory": true,
    "git@code-factory": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "gopls-daemon@code-factory": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "dual-agents-review@datadog-claude-plugins": true,
    "osx-notifications@datadog-claude-plugins": true,
    "skills@datadog-claude-plugins": true,
    "dd@datadog-claude-plugins": true,
    "writing@datadog-claude-plugins": true,
    "learning-skills@mrlee-plugins": true,
    "permissions-setup@mrlee-plugins": true,
    "valet@datadog-claude-plugins": true,
    "codex@openai-codex": true,
    "appgate@datadog-claude-plugins": true,
    "compute@datadog-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "datadog-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "DataDog/claude-marketplace"
      }
    },
    "code-factory": {
      "source": {
        "source": "github",
        "repo": "rtfpessoa/code-factory"
      }
    },
    "mrlee-plugins": {
      "source": {
        "source": "github",
        "repo": "DataDog/mrlee-plugins"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": false,
  "autoUpdatesChannel": "stable",
  "skipDangerousModePermissionPrompt": true,
  "model": "sonnet[1m]"
}
